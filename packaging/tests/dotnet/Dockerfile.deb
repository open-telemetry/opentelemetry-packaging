# End-to-end integration test image for the .NET auto-instrumentation DEB
# packages, on an apt-based .NET runtime base image. A build stage compiles the
# minimal ASP.NET app; the runtime stage installs the injector and .NET agent
# from a local APT repository. The injector activates the agent, which exports
# OTLP over HTTP to the otel-sink on the host; the Go test drives traffic and
# asserts on the exported telemetry.
#
# BASE_IMAGE (the runtime stage) is a build arg so the same Dockerfile covers
# multiple apt-based .NET base images. The OTLP endpoint and per-test test.id
# come from the sink's Env at run time.

ARG BASE_IMAGE=mcr.microsoft.com/dotnet/aspnet:9.0-bookworm-slim

FROM mcr.microsoft.com/dotnet/sdk:9.0-bookworm-slim AS build
COPY packaging/tests/shared/dotnet/ /src/
RUN dotnet publish /src/testapp.csproj -c Release -o /app/published --self-contained false

FROM ${BASE_IMAGE}

ARG ARCH=amd64

# Install utilities needed for local repo setup.
RUN apt-get update && apt-get install -y \
    dpkg-dev \
    gzip \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy the published app.
COPY --from=build /app/published /app/

# Copy pre-built packages and set up a local APT repository.
COPY build/local-repo/apt /local-repo
RUN echo 'deb [trusted=yes] file:///local-repo stable main' \
    > /etc/apt/sources.list.d/opentelemetry-local.list

# Install the injector and .NET auto-instrumentation packages from the local repo.
RUN apt-get update && apt-get install -y \
    opentelemetry-injector \
    opentelemetry-dotnet-autoinstrumentation

# Export OTLP for all signals. The endpoint, protocol, and test.id come from the
# sink's Env at run time; the shortened intervals get telemetry to the sink
# within the test window.
RUN { \
      echo 'OTEL_TRACES_EXPORTER=otlp'; \
      echo 'OTEL_METRICS_EXPORTER=otlp'; \
      echo 'OTEL_LOGS_EXPORTER=otlp'; \
      echo 'OTEL_SERVICE_NAME=dotnet-testapp'; \
      echo 'OTEL_BSP_SCHEDULE_DELAY=1000'; \
      echo 'OTEL_METRIC_EXPORT_INTERVAL=1000'; \
    } >> /etc/opentelemetry/injector/default_env.conf

EXPOSE 5000

CMD ["/bin/sh", "-c", "dotnet /app/testapp.dll 2>&1 | tee /tmp/app-output.log"]
