# End-to-end integration test image for the Python auto-instrumentation DEB
# package, on an apt-based base image. Installs the package from a local APT
# repository, activates the agent by prepending its directory to PYTHONPATH,
# then runs a minimal HTTP server that issues sqlite3 queries and emits a log
# record. The workload exports OTLP over HTTP to the otel-sink on the host.
#
# BASE_IMAGE and PYTHON_BIN are build args so the same Dockerfile covers multiple
# apt-based base images (e.g. debian:12, which ships Python 3.11 to match the
# bundled cp311 wheels). The OTLP endpoint and per-test test.id come from the
# sink's Env at run time.
#
# NOTE: activation is via PYTHONPATH rather than the opentelemetry-injector,
# because the injector does not yet implement the Python
# (python_auto_instrumentation_agent_path_prefix) conf.d key. Once it does, this
# image should install opentelemetry-injector and rely on it.

ARG BASE_IMAGE=debian:12
FROM ${BASE_IMAGE}

ARG ARCH=amd64
ARG PYTHON_BIN=python3
ENV PYTHON_BIN=${PYTHON_BIN}

# Install Python and utilities.
RUN apt-get update && apt-get install -y \
    ${PYTHON_BIN} \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy pre-built packages and set up a local APT repository.
COPY build/local-repo/apt /local-repo
RUN echo 'deb [trusted=yes] file:///local-repo stable main' \
    > /etc/apt/sources.list.d/opentelemetry-local.list

# Install the Python auto-instrumentation package from the local repo.
RUN apt-get update && apt-get install -y \
    opentelemetry-python-autoinstrumentation

# Copy the test server.
COPY packaging/tests/shared/python/app.py /app/app.py

# Export all three signals over OTLP. The exporter is intentionally left unset:
# sitecustomize.py defaults all signals to the bundled pure-Python exporter
# (otlp_pyproto_http); OTEL_EXPORTER_OTLP_PROTOCOL is set to http/protobuf by the
# sink's Env. Shortened schedule delays get telemetry to the sink within the test
# window, and log auto-instrumentation exports stdlib logging records as OTLP logs.
ENV PYTHONPATH=/usr/lib/opentelemetry/python \
    OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true \
    OTEL_SERVICE_NAME=python-testapp \
    OTEL_BSP_SCHEDULE_DELAY=1000 \
    OTEL_BLRP_SCHEDULE_DELAY=1000 \
    OTEL_METRIC_EXPORT_INTERVAL=1000 \
    OTEL_INJECTOR_LOG_LEVEL=debug

EXPOSE 8080

# Tee stdout/stderr to a file so container output is available for debugging.
CMD ["/bin/sh", "-c", "$PYTHON_BIN /app/app.py 2>&1 | tee /tmp/app-output.log"]
