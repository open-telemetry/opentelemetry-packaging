# Runs an unmodified Python one-liner with the packaged sitecustomize.py on
# PYTHONPATH, the way the injector activates it. The test asserts that the
# process always runs to completion, whatever the interpreter version.
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

COPY packaging/common/python/sitecustomize.py /otel-site/sitecustomize.py

ENV PYTHONPATH=/otel-site

# An unsupported protocol makes the protocol guard deactivate deterministically
# on supported interpreters (3.10+), proving the version gate let them through.
# On older interpreters the version gate fires first, so this is irrelevant to
# them. (An unset protocol now defaults to grpc and would proceed to activate.)
ENV OTEL_EXPORTER_OTLP_PROTOCOL=http/json

CMD ["python", "-c", "print('APP RAN TO COMPLETION')"]
