# End-to-end integration test image for the Node.js auto-instrumentation RPM
# packages, on a dnf-based base image. Installs the injector and Node.js agent
# from a local YUM repository, then runs a minimal HTTP server. The injector
# activates the agent, which exports OTLP over HTTP to the otel-sink on the host;
# the Go test drives traffic and asserts on the exported telemetry.
#
# BASE_IMAGE is a build arg so the same Dockerfile covers multiple dnf-based base
# images. The OTLP endpoint and per-test test.id come from the sink's Env at run
# time.

ARG BASE_IMAGE=fedora:41
FROM ${BASE_IMAGE}

ARG ARCH=amd64
ARG RPM_ARCH=x86_64

ENV LANG=C.UTF-8

# Install Node.js and utilities.
RUN dnf -y update \
    && dnf -y install nodejs curl \
    && dnf clean all

# Copy pre-built packages and repository metadata.
COPY build/local-repo/rpm /local-repo
RUN printf '[opentelemetry-local]\nname=OpenTelemetry Local\nbaseurl=file:///local-repo/packages\nenabled=1\ngpgcheck=0\n' \
    > /etc/yum.repos.d/opentelemetry-local.repo

# Install the injector and Node.js auto-instrumentation packages from the local repo.
RUN dnf install -y \
    opentelemetry-injector \
    opentelemetry-nodejs-autoinstrumentation

# Export OTLP for all signals. The endpoint, protocol, and test.id come from the
# sink's Env at run time; the shortened intervals get telemetry to the sink
# within the test window.
RUN { \
      echo 'OTEL_TRACES_EXPORTER=otlp'; \
      echo 'OTEL_METRICS_EXPORTER=otlp'; \
      echo 'OTEL_LOGS_EXPORTER=otlp'; \
      echo 'OTEL_SERVICE_NAME=nodejs-testapp'; \
      echo 'OTEL_BSP_SCHEDULE_DELAY=1000'; \
      echo 'OTEL_METRIC_EXPORT_INTERVAL=1000'; \
    } >> /etc/opentelemetry/injector/default_env.conf

# Copy the test server.
COPY packaging/tests/shared/nodejs/server.js /app/server.js

EXPOSE 3000

CMD ["/bin/sh", "-c", "node /app/server.js 2>&1 | tee /tmp/app-output.log"]
